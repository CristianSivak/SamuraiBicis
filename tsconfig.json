{
  "compilerOptions": {
    "types": ["vite/client"],
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "target": "ES2020",
    "allowJs": true,
    "paths": {
      "react-hook-form": ["src/vendor/react-hook-form.tsx"],
      "@hookform/resolvers/zod": ["src/vendor/hookform-resolvers-zod.ts"],
      "zod": ["src/vendor/zod.js"]
    }
  },
  "include": ["src"]
}
